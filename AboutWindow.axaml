<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        Width="250" Height="150" CanResize="False"
        x:Class="Enviredit.AboutWindow"
        WindowStartupLocation="CenterOwner"
        Title="About">
    <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock x:Name="MainBlock" Text="Enviredit" FontWeight="Bold" FontSize="24" TextAlignment="Center"/>
        <TextBlock Text="A free and open source text editor" TextAlignment="Center"/>
        <TextBlock Text=" " TextAlignment="Center"/>
        <TextBlock Text="Version: DEV BRANCH (main)" TextAlignment="Center"/>
    </StackPanel>
</Window>
